# -----------------------------------------------
# Helm artifacts
# -----------------------------------------------
# Packaged chart tarballs (output of `helm package`)
*.tgz

# Downloaded chart dependencies (output of `helm dependency update`)
charts/*/charts/

# Dependency lock files are intentionally NOT ignored — commit Chart.lock
# so downstream installs are reproducible.

# -----------------------------------------------
# chart-testing / ct temp output
# -----------------------------------------------
.ct/
ct-output/

